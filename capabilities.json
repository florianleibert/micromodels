{
  "schema_version": "1",
  "server": {
    "api": "openai-chat-completions-subset",
    "supports_streaming": true,
    "supports_tools": false,
    "supports_system_role": true,
    "auth": {
      "bearer_token_env": "FLOCODE_SERVE_TOKEN",
      "optional": true
    },
    "endpoints": {
      "public": ["/healthz", "/v1/models"],
      "authed": ["/metrics", "/v1/chat/completions"]
    }
  },
  "models": [
    {
      "id": "micromodel-qwen3-4b-dflash",
      "display_name": "Qwen3-4B DFlash (MLX)",
      "backend": "dflash",
      "target": "mlx-community/Qwen3-4B-bf16",
      "draft": "z-lab/Qwen3-4B-DFlash-b16",
      "verifier_mode": "parallel-replay",
      "context_tokens": 32768,
      "architecture": "apple_silicon_mlx",
      "licenses": ["apache-2.0"],
      "approx_ram_gb": 10,
      "approx_disk_gb": 18,
      "notes": "Exact speculative decoding. No tool calls. No prefix cache."
    },
    {
      "id": "micromodel-gemma-3n-e2b",
      "display_name": "Gemma 3n E2B (plain MLX)",
      "backend": "plain_mlx",
      "target": "mlx-community/gemma-3n-E2B-it-bf16",
      "draft": null,
      "context_tokens": 32768,
      "architecture": "apple_silicon_mlx",
      "licenses": ["gemma"],
      "approx_ram_gb": 4,
      "approx_disk_gb": 10,
      "notes": "Plain MLX. No DFlash speedup. Use --target-model to substitute a 4-bit quant for lighter RAM."
    },
    {
      "id": "micromodel-qwen3-30b-a3b-instruct",
      "display_name": "Qwen3-30B-A3B Instruct 4-bit (MoE, plain MLX)",
      "backend": "plain_mlx",
      "target": "mlx-community/Qwen3-30B-A3B-Instruct-2507-4bit",
      "draft": null,
      "context_tokens": 131072,
      "architecture": "apple_silicon_mlx",
      "licenses": ["apache-2.0"],
      "approx_ram_gb": 20,
      "approx_disk_gb": 18,
      "notes": "MoE (3B active). Plain MLX. No DFlash speedup. Best for quality over decode speed. Use --target-model to swap bit-widths."
    }
  ]
}
